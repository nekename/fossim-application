{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "fossim-application",
	"version": "0.1.0",
	"identifier": "fossim",
	"build": {
		"beforeDevCommand": "deno task dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "deno task build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "Fossim",
				"width": 800,
				"height": 600,
				"maximized": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"]
	}
}
